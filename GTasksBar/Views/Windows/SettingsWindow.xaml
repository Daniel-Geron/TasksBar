<ui:FluentWindow x:Class="GTasksBar.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Settings" Height="580" Width="600" 
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Topmost="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="800" Margin="20,10,20,30">

                <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <ui:CardControl Icon="{ui:SymbolIcon PaintBucket24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Window Backdrop" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Use an Acrylic blur effect instead of Mica" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="AcrylicToggle" Click="Setting_Changed" />
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,24">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Application Theme" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Override the default Windows theme" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox x:Name="ThemeComboBox" Width="120" SelectionChanged="Setting_Changed">
                        <ComboBoxItem Content="System Default"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </ui:CardControl>

                <TextBlock Text="Behavior &amp; Sync" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <ui:CardControl Icon="{ui:SymbolIcon CloudArrowUp24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Google Tasks Sync" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Keep tasks synchronized with your Google account" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="GoogleSyncToggle" Click="Setting_Changed" />
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon CheckmarkSquare24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Show Completed Tasks" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Keep finished tasks visible in the list" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="ShowCompletedToggle" Click="Setting_Changed" />
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Rocket24}" Margin="0,0,0,24">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Launch on Startup" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Start GTasksBar automatically with Windows" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="StartupToggle" Click="Setting_Changed" />
                </ui:CardControl>

                <TextBlock Text="Widget Layout" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <ui:CardControl Icon="{ui:SymbolIcon LockClosed24}" Margin="0,0,0,4">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Lock Position" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Prevent the widget from being dragged" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="LockToggle" Click="Setting_Changed" />
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon ArrowMove24}" Margin="0,0,0,30">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Default Location" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                            <TextBlock Text="Where the widget snaps to on the screen" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox x:Name="PositionComboBox" Width="140" SelectionChanged="Setting_Changed">
                        <ComboBoxItem Content="Top Left"/>
                        <ComboBoxItem Content="Top Center"/>
                        <ComboBoxItem Content="Top Right"/>
                        <ComboBoxItem Content="Bottom Left"/>
                        <ComboBoxItem Content="Bottom Center"/>
                        <ComboBoxItem Content="Bottom Right"/>
                    </ComboBox>
                </ui:CardControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>