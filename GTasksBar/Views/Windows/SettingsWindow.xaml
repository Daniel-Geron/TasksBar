<ui:FluentWindow x:Class="GTasksBar.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Settings" Height="480" Width="350"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,30,0,0">
        <Grid Margin="20,10,20,20">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                <TextBlock Text="Appearance" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                <ui:ToggleSwitch x:Name="AcrylicToggle" Content="Use Acrylic blur (instead of Mica)" Margin="0,0,0,15"/>

                <TextBlock Text="Behavior" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                <ui:ToggleSwitch x:Name="TopmostToggle" Content="Keep window always on top" Margin="0,0,0,15"/>
                <ui:ToggleSwitch x:Name="GoogleSyncToggle" Content="Enable Google Tasks Sync" Margin="0,0,0,15"/>
                <ui:ToggleSwitch x:Name="LockToggle" Content="Lock window position (Disable Dragging)" Margin="0,0,0,15"/>

                <TextBlock Text="Widget Position" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                <ComboBox x:Name="PositionComboBox" SelectedIndex="5">
                    <ComboBoxItem Content="Top Left"/>
                    <ComboBoxItem Content="Top Center"/>
                    <ComboBoxItem Content="Top Right"/>
                    <ComboBoxItem Content="Bottom Left"/>
                    <ComboBoxItem Content="Bottom Center"/>
                    <ComboBoxItem Content="Bottom Right"/>
                </ComboBox>

                <ui:Button Content="Save &amp; Apply" Appearance="Primary" Margin="0,30,0,0" HorizontalAlignment="Stretch" Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</ui:FluentWindow>