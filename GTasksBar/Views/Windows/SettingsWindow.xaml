<ui:FluentWindow x:Class="GTasksBar.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Settings" Height="600" Width="800" 
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 Topmost="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Title="Settings" />

        <Border Grid.Row="1" Grid.Column="0" Background="Transparent" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}">
            <ListBox x:Name="SidebarList" Background="Transparent" BorderThickness="0" Margin="10,20,10,10" SelectionChanged="SidebarList_SelectionChanged">

                <ListBoxItem Padding="12,10" Margin="0,0,0,4">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PaintBucket24" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Appearance &amp; Layout" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CloudArrowUp24" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Behavior &amp; Sync" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

            </ListBox>
        </Border>

        <Frame x:Name="RootFrame" Grid.Row="1" Grid.Column="1" NavigationUIVisibility="Hidden" Background="Transparent"/>

    </Grid>
</ui:FluentWindow>