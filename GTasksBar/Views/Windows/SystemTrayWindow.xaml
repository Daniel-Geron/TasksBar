<ui:FluentWindow x:Class="GTasksBar.SystemTrayWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 Visibility="Hidden"
                 ShowInTaskbar="False">
    <Grid>
        <tray:NotifyIcon
    x:Name="TaskbarIcon"
    TooltipText="Google Tasks"
    LeftClick="TaskbarIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <MenuItem Header="Tasks Flyout" Click="OpenFlyout_Click"/>
                    <MenuItem Header="Sticky Note" Click="OpenStickyNote_Click"/>
                    <Separator/>
                    <MenuItem Header="Quit" Click="Quit_Click"/>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>