<ui:FluentWindow x:Class="GTasksBar.TasksFlyoutWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:GTasksBar"
                 Title="My Tasks" Height="450" Width="320"
                 WindowStartupLocation="Manual" 
                 ShowInTaskbar="False"
                 WindowStyle="None"
                 ResizeMode="CanMinimize" 
                 WindowBackdropType="Acrylic"
                 ExtendsContentIntoTitleBar="True"
                 TextOptions.TextRenderingMode="ClearType" 
                 TextOptions.TextFormattingMode="Ideal">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <local:AutoRtlConverter x:Key="AutoRtlConverter" />
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid Margin="12,12,12,6" Background="Transparent" MouseLeftButtonDown="RootGrid_MouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style TargetType="ui:Snackbar" BasedOn="{StaticResource {x:Type ui:Snackbar}}">
                <Setter Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
            </Style>
        </Grid.Resources>

        <Grid Grid.Row="0" Margin="0,0,0,16" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsHitTestVisible="False">
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button x:Name="PinButton" Appearance="Transparent" Icon="{ui:SymbolIcon Symbol=Pin20}" Click="PinButton_Click" Padding="4" Margin="0,0,4,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:Button Appearance="Transparent" Icon="{ui:SymbolIcon Symbol=Settings20, Filled=True}" Click="Settings_Click" Padding="4" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <ui:Button Grid.Row="1" Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="4,8" Margin="0,0,0,12" Click="AddTaskTop_Click">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Add20" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="Add a task" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </ui:Button>

        <ListView Grid.Row="2" x:Name="TasksListView" Margin="0,0,0,12" BorderThickness="0" Background="Transparent" 
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="False"
                  MouseLeftButtonDown="RootGrid_MouseDown"
                  SelectionMode="Single">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Focusable" Value="False" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="IsTabStop" Value="False"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate DataType="{x:Type local:TaskItem}">
                    <Border x:Name="TaskCard" Background="Transparent" CornerRadius="6" Padding="10,8" BorderThickness="0" LostFocus="TaskCard_LostFocus">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsCompleted}" VerticalAlignment="Top" Margin="0,3,10,0"
                                          Click="CompleteTask_Click" Tag="{Binding}" Background="Transparent" BorderThickness="0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Grid Background="Transparent" Width="18" Height="18" RenderTransformOrigin="0.5,0.5">
                                                        <Grid.RenderTransform>
                                                            <ScaleTransform x:Name="ControlScale" ScaleX="1" ScaleY="1"/>
                                                        </Grid.RenderTransform>

                                                        <Ellipse x:Name="OuterRing" StrokeThickness="1.5" Stroke="{DynamicResource TextFillColorSecondaryBrush}"/>

                                                        <Ellipse x:Name="InnerDot" Fill="{DynamicResource SystemAccentColorPrimaryBrush}" Width="10" Height="10" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <Ellipse.RenderTransform>
                                                                <ScaleTransform ScaleX="0" ScaleY="0"/>
                                                            </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                    </Grid>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.15">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15"/>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>

                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleX" To="0.85" Duration="0:0:0.05"/>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleY" To="0.85" Duration="0:0:0.05"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleX" To="1.15" Duration="0:0:0.1"/>
                                                                        <DoubleAnimation Storyboard.TargetName="ControlScale" Storyboard.TargetProperty="ScaleY" To="1.15" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>

                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="OuterRing" Property="Stroke" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="InnerDot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.0"/>
                                                                        <DoubleAnimation Storyboard.TargetName="InnerDot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.3">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <BackEase EasingMode="EaseOut" Amplitude="0.6"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetName="InnerDot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.3">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <BackEase EasingMode="EaseOut" Amplitude="0.6"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="InnerDot" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                                                        <DoubleAnimation Storyboard.TargetName="InnerDot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseIn"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetName="InnerDot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseIn"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <StackPanel Grid.Column="1" Margin="0,0,6,0">
                                <ui:TextBox x:Name="TaskTitleInput" 
                                            Text="{Binding Title, UpdateSourceTrigger=LostFocus}"
                                            TextWrapping="Wrap"
                                            ClearButtonEnabled="False"
                                            AcceptsReturn="False"
                                            MaxLines="4"
                                            VerticalContentAlignment="Top"
                                            KeyDown="TaskTitleInput_KeyDown"
                                            FontSize="14" FontWeight="Medium" 
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" 
                                            BorderThickness="0" Background="Transparent" Padding="0,0,0,2"
                                            PlaceholderText="Task title"
                                            Loaded="TaskTitleInput_Loaded"
                                            FlowDirection="{Binding Text, RelativeSource={RelativeSource Self}, Converter={StaticResource AutoRtlConverter}}">

                                    <ui:TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlElevationBorderBrush" Color="Transparent" />
                                    </ui:TextBox.Resources>
                                </ui:TextBox>

                                <ui:TextBox x:Name="TaskDetailsInput"
                                            ClearButtonEnabled="False"
                                            Text="{Binding Details, UpdateSourceTrigger=LostFocus}"
                                            TextWrapping="Wrap"
                                            AcceptsReturn="True"
                                            VerticalContentAlignment="Top"
                                            PlaceholderText="Add details" 
                                            BorderThickness="0" Background="Transparent" 
                                            Padding="0,2,0,0" FontSize="12" 
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            FlowDirection="{Binding Text, RelativeSource={RelativeSource Self}, Converter={StaticResource AutoRtlConverter}}">

                                    <ui:TextBox.Resources>
                                        <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                        <SolidColorBrush x:Key="TextControlElevationBorderBrush" Color="Transparent" />
                                    </ui:TextBox.Resources>

                                    <ui:TextBox.Style>
                                        <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TaskCard}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasDetails}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:TextBox.Style>
                                </ui:TextBox>
                            </StackPanel>

                            <ui:Button x:Name="MoreButton" Grid.Column="2" Appearance="Transparent" VerticalAlignment="Top" 
                                       Icon="{ui:SymbolIcon Symbol=MoreHorizontal20}" Padding="2" Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Click="MoreOptions_Click" Tag="{Binding}" Opacity="0"/>
                        </Grid>
                    </Border>

                    <DataTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True" SourceName="TaskCard">
                            <Setter TargetName="MoreButton" Property="Opacity" Value="1"/>
                            <Setter TargetName="TaskCard" Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                        </Trigger>

                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                            <Setter TargetName="TaskTitleInput" Property="TextDecorations" Value="Strikethrough"/>
                            <Setter TargetName="TaskTitleInput" Property="Opacity" Value="0.5"/>
                            <Setter TargetName="TaskDetailsInput" Property="Opacity" Value="0.5"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Rectangle Grid.Row="3" Fill="{DynamicResource SystemAccentColorPrimaryBrush}" Height="4" RadiusX="2" RadiusY="2" Width="60" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>

        <ui:SnackbarPresenter x:Name="RootSnackbar" Grid.RowSpan="4" VerticalAlignment="Bottom" Margin="0,0,0,20"/>

    </Grid>
</ui:FluentWindow>